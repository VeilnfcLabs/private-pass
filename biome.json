{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "organizeImports": {
    "enabled": false
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always"
    }
  },
  "files": {
    "include": [
      "apps/web/src/**/*.ts",
      "apps/web/src/**/*.tsx",
      "cli/src/**/*.ts",
      "apps/docs/src/**/*.ts",
      "apps/docs/src/**/*.tsx"
    ],
    "ignore": [
      "**/node_modules",
      "**/dist",
      "**/.next",
      "**/target"
    ]
  }
}
