# VeilPass Docker Compose Environment Variables
# Copy this file to .env and fill in your values.
#   cp .env.example .env

# ── Signing Keys ───────────────────────────────────────────────────────────────
# Ed25519 signing key (hex-encoded 64-byte seed + public key).
# Generate with:  openssl rand -hex 32
VEILPASS_SIGNING_KEY=

# Ed25519 verification key (hex-encoded 32-byte public key).
# Derived from the signing key if not set.
VEILPASS_VERIFICATION_KEY=

# ── Database ───────────────────────────────────────────────────────────────────
VEILPASS_DATABASE_URL=postgresql+asyncpg://veilpass:veilpass@localhost:5432/veilpass

# ── Redis ──────────────────────────────────────────────────────────────────────
VEILPASS_REDIS_URL=redis://localhost:6379/0

# ── Rate Limiting ──────────────────────────────────────────────────────────────
VEILPASS_RATE_LIMIT=100

# ── Frontend ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
